// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String         @id @default(uuid())
  email               String         @unique
  passwordHash        String         @map("password_hash")
  name                String
  createdAt           DateTime       @default(now()) @map("created_at")

  createdGroups       Group[]        @relation("GroupCreator")
  groupMemberships    GroupMember[]
  paidExpenses        Expense[]      @relation("ExpensePayer")
  expenseSplits       ExpenseSplit[]
  sentSettlements     Settlement[]   @relation("SettlementSender")
  receivedSettlements Settlement[]   @relation("SettlementReceiver")
  messages            Message[]

  @@map("users")
}

model Group {
  id          String        @id @default(uuid())
  name        String
  creatorId   String        @map("creator_id")
  creator     User          @relation("GroupCreator", fields: [creatorId], references: [id])
  createdAt   DateTime      @default(now()) @map("created_at")

  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]

  @@map("groups")
}

model GroupMember {
  id       String    @id @default(uuid())
  groupId  String    @map("group_id")
  group    Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String    @map("user_id")
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime  @default(now()) @map("joined_at")
  leftAt   DateTime? @map("left_at")
  isActive Boolean   @default(true) @map("is_active")

  @@unique([groupId, userId])
  @@map("group_members")
}

enum SplitType {
  EQUAL
  UNEQUAL
  PERCENTAGE
  SHARE
}

model Expense {
  id               String         @id @default(uuid())
  groupId          String         @map("group_id")
  group            Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidById         String         @map("paid_by_id")
  paidBy           User           @relation("ExpensePayer", fields: [paidById], references: [id])
  amount           Decimal        @db.Decimal(12, 2)
  originalAmount   Decimal        @default(0.00) @db.Decimal(12, 2) @map("original_amount")
  originalCurrency String         @default("INR") @map("original_currency")
  convertedAmount  Decimal        @default(0.00) @db.Decimal(12, 2) @map("converted_amount")
  description      String
  createdAt        DateTime       @default(now()) @map("created_at")

  splits           ExpenseSplit[]
  messages         Message[]

  @@map("expenses")
}

model ExpenseSplit {
  id         String    @id @default(uuid())
  expenseId  String    @map("expense_id")
  expense    Expense   @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount     Decimal   @db.Decimal(12, 2)
  splitValue Decimal   @map("split_value") @db.Decimal(12, 2)
  splitType  SplitType @map("split_type")

  @@map("expense_splits")
}

model Settlement {
  id         String   @id @default(uuid())
  groupId    String   @map("group_id")
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderId   String   @map("sender_id")
  sender     User     @relation("SettlementSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String   @map("receiver_id")
  receiver   User     @relation("SettlementReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  amount     Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("settlements")
}

model Message {
  id          String   @id @default(uuid())
  expenseId   String   @map("expense_id")
  expense     Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  senderId    String   @map("sender_id")
  sender      User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  messageText String   @map("message_text")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("messages")
}

model Import {
  id        String          @id @default(uuid())
  filename  String
  status    String          // "COMPLETED", "PARTIAL", "FAILED"
  createdAt DateTime        @default(now()) @map("created_at")
  anomalies ImportAnomaly[]

  @@map("imports")
}

model ImportAnomaly {
  id          String           @id @default(uuid())
  importId    String           @map("import_id")
  import      Import           @relation(fields: [importId], references: [id], onDelete: Cascade)
  rowNumber   Int              @map("row_number")
  anomalyType String           @map("anomaly_type")
  description String
  actionTaken String           @map("action_taken")
  approvals   ImportApproval[]

  @@map("import_anomalies")
}

model ImportApproval {
  id         String        @id @default(uuid())
  anomalyId  String        @map("anomaly_id")
  anomaly    ImportAnomaly @relation(fields: [anomalyId], references: [id], onDelete: Cascade)
  action     String        // e.g. "CREATE_EXPENSE"
  status     String        // "PENDING", "APPROVED", "REJECTED"
  rowData    Json          @map("row_data")
  approvedBy String?       @map("approved_by")
  createdAt  DateTime      @default(now()) @map("created_at")

  @@map("import_approvals")
}
